# ── AWS / Cognito ──────────────────────────────────────────
AWS_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_USER_POOL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# ── RDS PostgreSQL ────────────────────────────────────────
DATABASE_URL=postgresql://vendorcheck:password@localhost:5432/vendorcheck

# ── S3 ────────────────────────────────────────────────────
S3_DOCUMENTS_BUCKET=vendorcheck-documents-dev

# ── SNS ───────────────────────────────────────────────────
SNS_ALERTS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:vendorcheck-alerts-dev

# ── Step Functions ────────────────────────────────────────
STEP_FUNCTIONS_STATE_MACHINE_ARN=arn:aws:states:us-east-1:123456789012:stateMachine:vendorcheck-doc-pipeline-dev

# ── Legacy Supabase (kept during migration, remove after Phase 4) ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ── CORS ──────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── Environment ───────────────────────────────────────────
APP_ENV=development
